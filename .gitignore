# =============================================================================
# .gitignore for NS3-SOM-MD
# =============================================================================

# --- Large trajectory and topology files ---
*.xtc
*.trr
*.dcd
*.tpr
*.edr
*.cpt
*.tng

# --- Large PDB trajectory files (generated by gmx trjconv) ---
data/*_ca.pdb
data/holo_ca.pdb
data/apo_ca.pdb

# --- GROMACS index files ---
*.ndx

# --- R workspace and history ---
.RData
.Rhistory
*.Rproj.user/
*.Rproj

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Temporary R files ---
*~
\#*\#

# --- Results (optional: uncomment to exclude from git) ---
# results/figures/*.png
# results/structures/*.pdb
# results/structures/*.csv
